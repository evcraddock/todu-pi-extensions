{
  "name": "todu-pi-extensions",
  "version": "0.1.0",
  "private": true,
  "description": "Task manager extensions for the pi agent harness that create UI for handling tasks.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "todu",
    "tasks",
    "tui"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm test",
    "pre-pr": "./scripts/pre-pr.sh"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.60.0",
    "@mariozechner/pi-tui": "^0.60.0",
    "@sinclair/typebox": "^0.34.48",
    "@todu/core": "^0.14.2",
    "yaml": "^2.8.2"
  }
}
